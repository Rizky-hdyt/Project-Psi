generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model District {
  id                     String          @id
  nama                   String
  tipe                   String
  umk                    Int
  coworkingCount         Int
  internetMbps           Int
  kostMin                Int
  kostMax                Int
  estimasiBiayaHidup     Int
  ringkasanKarakteristik String
  scores                 DistrictScore[]
  auditLogs              AuditLog[]
  subDistricts           SubDistrict[]
}

model DistrictScore {
  id          String   @id @default(cuid())
  districtId  String
  indicatorId String
  skor        Float
  updatedAt   DateTime @default(now()) @updatedAt
  district    District @relation(fields: [districtId], references: [id])

  @@unique([districtId, indicatorId])
}

// Kecamatan — level ranking kedua di dalam satu distrik (lihat rankSubDistricts).
// UMK tidak disimpan di sini karena di Indonesia UMK ditetapkan per Kabupaten/Kota,
// bukan per kecamatan — semua kecamatan dalam satu distrik berbagi umk induknya.
model SubDistrict {
  id                     String             @id
  districtId             String
  nama                   String
  latitude               Float?
  longitude              Float?
  estimasiBiayaHidup     Int
  coworkingCount         Int
  cafeCount              Int
  universityCount        Int
  tourismScore           Float
  ringkasanKarakteristik String
  district               District           @relation(fields: [districtId], references: [id])
  scores                 SubDistrictScore[]
}

model SubDistrictScore {
  id            String      @id @default(cuid())
  subDistrictId String
  indicatorId   String
  skor          Float
  updatedAt     DateTime    @default(now()) @updatedAt
  subDistrict   SubDistrict @relation(fields: [subDistrictId], references: [id])

  @@unique([subDistrictId, indicatorId])
}

model AuditLog {
  id              String   @id @default(cuid())
  districtId      String
  indicatorId     String
  nilaiLama       Float
  nilaiBaru       Float
  operator        String
  createdAt       DateTime @default(now())
  district        District @relation(fields: [districtId], references: [id])
  // Diisi kalau entri ini sebenarnya tentang kecamatan (districtId tetap diisi
  // = distrik induknya, supaya relasi lama tidak perlu berubah).
  subDistrictId   String?
  subDistrictNama String?
}

model Survey {
  id        String   @id @default(cuid())
  relevansi Int
  kemudahan Int
  komentar  String?
  personaId String?
  createdAt DateTime @default(now())
}
